{
  "name": "svg-vectorizer",
  "version": "0.2.0",
  "description": "Convert raster images into clean or high-fidelity SVGs with validation and optional repair.",
  "author": {
    "name": "SVG Vectorizer Contributors",
    "url": "https://github.com/w2030298-art/svg-vectorizer-codex-plugin"
  },
  "homepage": "https://github.com/w2030298-art/svg-vectorizer-codex-plugin",
  "repository": "https://github.com/w2030298-art/svg-vectorizer-codex-plugin",
  "license": "MIT",
  "keywords": [
    "svg",
    "vtracer",
    "vectorization",
    "image-processing"
  ],
  "mcpServers": {
    "svgVectorizer": {
      "type": "stdio",
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/server/mcp-server.cjs"]
    }
  }
}
